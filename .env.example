# ملف إعدادات بيئة التطبيق - تطبيق كرين
# انسخ هذا الملف إلى .env وأضف بياناتك الخاصة هنا.

# ============ إعدادات التطبيق الأساسية ============
APP_URL=https://kreen-app.onrender.com
DB_PATH=/var/www/html/kreen.db
APP_DEBUG=false
APP_TIMEZONE=Asia/Baghdad
SESSION_TIMEOUT=1800

# ============ إعدادات البريد الإلكتروني SMTP ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=tls
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=تطبيق كرين

# ============ إعدادات Telegram (التنبيهات) ============
ENABLE_TELEGRAM=true
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# ============ إعدادات الخدمة ============
SERVICE_FEE_IQD=5000

# ============ إعدادات WAF (جدار الحماية) ============
PROXY_ENABLED=true
UPSTREAM_URL=http://127.0.0.1:8080
ADMIN_PASSWORD=your-secure-password-here
ENABLE_PROXY_VPN_DETECTION=true
PROXY_VPN_REFRESH_SECONDS=3600
TRUSTED_PROXY_NETWORKS=127.0.0.1/32,::1/128

# 🔐 إعدادات التليجرام (Telegram Configuration)
# احصل على التوكن من @BotFather على Telegram
TELEGRAM_TOKEN=YOUR_BOT_TOKEN_HERE

# احصل على Chat ID من @userinfobot أو من مجموعتك
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

# تفعيل أو تعطيل التنبيهات
ENABLE_TELEGRAM=True

# 🔑 الأمان (Security)
# يجب ضبط كلمة مرور قوية للمسارات الإدارية
ADMIN_PASSWORD=change_this_secure_password

# قائمة IPs أو الشبكات المسموح لها باستخدام المسارات الإدارية
ADMIN_ALLOWED_IPS=127.0.0.1,::1

# ⚙️ إعدادات الحماية (Protection Settings)
# عدد الطلبات المريبة قبل حظر IP دائم
BAN_THRESHOLD=5

# عدد الطلبات في الثانية قبل اعتبارها DDoS
DDOS_THRESHOLD=50

# 🌐 إعدادات التطبيق (Application Settings)
# بيئة التشغيل: development أو production
FLASK_ENV=production
PROXY_ENABLED=True
UPSTREAM_URL=http://127.0.0.1:8000

# تفعيل وضع الـ Debug (لا تفعله في الإنتاج!)
FLASK_DEBUG=False

# 📝 إعدادات السجل (Logging)
# مستوى التسجيل: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 📊 قاعدة البيانات (Database - اختياري)
# DATABASE_URL=mysql://user:password@localhost/waf_db

# 🔗 CORS (للـ APIs - اختياري)
# ALLOWED_ORIGINS=https://your-domain.com,https://admin.your-domain.com

# 💾 تخزين البيانات (Storage)
# MAX_LOG_SIZE=100M
# LOG_RETENTION_DAYS=30
